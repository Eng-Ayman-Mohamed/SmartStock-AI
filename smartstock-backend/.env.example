# =============================================================================
# SmartStock AI — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Required vars are marked [Required]. All others have safe defaults.

# ---- Django Core ----
DJANGO_SECRET_KEY=                   # [Required] Secret key for crypto signing
DJANGO_DEBUG=True                    # [Optional] True for development, False for production
ALLOWED_HOSTS=localhost,127.0.0.1    # [Optional] Comma-separated allowed hostnames

# ---- Database ----
DATABASE_URL=postgres://smartstock:smartstock@localhost:5432/smartstock  # [Required] PostgreSQL connection URL
DB_USER=smartstock                   # [Optional] Used if DATABASE_URL is not set (base.py fallback)
DB_PASSWORD=smartstock               # [Optional] Used if DATABASE_URL is not set (base.py fallback)
DB_HOST=localhost                    # [Optional] Used if DATABASE_URL is not set (base.py fallback)
DB_PORT=5432                         # [Optional] Used if DATABASE_URL is not set (base.py fallback)
DB_NAME=smartstock                   # [Optional] Used if DATABASE_URL is not set (base.py fallback)

# ---- Redis / Celery ----
REDIS_URL=redis://localhost:6379/1   # [Required] Redis for cache + Celery broker/result backend
CELERY_BROKER_URL=redis://localhost:6379/0  # [Optional] Falls back to REDIS_URL
CELERY_RESULT_BACKEND=redis://localhost:6379/0  # [Optional] Falls back to REDIS_URL

# ---- AI / ML ----
OPENAI_API_KEY=                      # [Required] OpenAI API key for GPT-4o, embeddings, Whisper
COHERE_API_KEY=                      # [Required] Cohere API key for RAG reranking

# ---- Langfuse Observability (optional) ----
LANGFUSE_PUBLIC_KEY=                 # [Optional] Leave empty to disable Langfuse
LANGFUSE_SECRET_KEY=                 # [Optional] Leave empty to disable Langfuse
LANGFUSE_HOST=https://cloud.langfuse.com  # [Optional] Langfuse server URL
LANGFUSE_DAILY_TOKEN_BUDGET=1000000  # [Optional] Daily token spend cap for alerts

# ---- CORS / CSRF ----
CORS_ALLOWED_ORIGINS=http://localhost:5173  # [Optional] Comma-separated frontend origins
CSRF_TRUSTED_ORIGINS=                # [Optional] Production only; defaults to https://smart-stock-dev.vercel.app

# ---- Email (production only) ----
EMAIL_HOST=                          # [Optional] SMTP host (required for email in production)
EMAIL_PORT=587                       # [Optional] SMTP port
EMAIL_HOST_USER=                     # [Optional] SMTP username
EMAIL_HOST_PASSWORD=                 # [Optional] SMTP password
DEFAULT_FROM_EMAIL=noreply@smartstock.ai  # [Optional] Sender address

# ---- Escalation Notifications ----
ESCALATION_RECIPIENT_EMAILS=         # [Optional] Comma-separated emails; disabled if empty

# ---- Storage ----
CLOUDINARY_URL=                      # [Optional] Cloudinary URL for document uploads; disabled if empty

# ---- CI ----
CI=                                  # [Optional] Set to 'true' in CI to skip env validation
