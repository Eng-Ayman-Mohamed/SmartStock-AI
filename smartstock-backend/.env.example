# =============================================================================
# SmartStock AI — Backend environment configuration
# Copy this file to `.env` and fill in real values. The `.env` file is
# git-ignored and must never be committed.
#
# REQUIRED variables: the app will refuse to start if any are missing.
# OPTIONAL variables: defaults are shown in brackets after the description.
# =============================================================================

# =============================================================================
# REQUIRED — The app will raise ImproperlyConfigured at startup if missing
# =============================================================================

# Django core
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string

# Database — Render PostgreSQL / Neon PostgreSQL
# Render:  paste the connection string from your managed database service
# Neon:    paste from https://console.neon.tech → "Connection Details" → "Pooled connection"
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/smartstock

# Redis (broker + cache + Celery)
# Render:  paste the connection string from your managed Redis service
# Local:   a Redis running on localhost (e.g. `docker run -p 6379:6379 redis`)
REDIS_URL=redis://localhost:6379/0

# AI / LLM
OPENAI_API_KEY=

# Langfuse — LLM observability and tracing
# Sign up at https://cloud.langfuse.com and create a project.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Cohere — embeddings for RAG
COHERE_API_KEY=

# Cloudinary — document/image storage for RAG ingestion
# Get your CLOUDINARY_URL from https://console.cloudinary.com
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# =============================================================================
# OPTIONAL — Defaults shown in brackets; override as needed
# =============================================================================

# Langfuse host URL [default: https://cloud.langfuse.com]
# LANGFUSE_HOST=https://cloud.langfuse.com

# Langfuse daily token budget alert threshold [default: 1000000]
# LANGFUSE_DAILY_TOKEN_BUDGET=1000000

# Django debug mode [default: False]
# DJANGO_DEBUG=False

# Allowed hosts (comma-separated) [default: localhost,127.0.0.1]
# Render adds .onrender.com automatically in production settings.
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# CORS / CSRF (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://smartstock-ai.vercel.app,https://smart-stock-dev.vercel.app
CSRF_TRUSTED_ORIGINS=https://smartstock-ai.vercel.app,https://smart-stock-dev.vercel.app

# Legacy database fallback (only used if DATABASE_URL is unset)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=smartstock
DB_USER=smartstock
DB_PASSWORD=smartstock
DB_HOST=localhost
DB_PORT=5432

# Celery broker/result (defaults to REDIS_URL if unset)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email (SendGrid)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@smartstock.ai

# CI flag (set to True in CI environments)
CI=True

# =============================================================================
# Render deployment checklist:
#   1. Import render.yaml as a Blueprint in the Render Dashboard
#   2. Set these secret env vars in each service's dashboard:
#      OPENAI_API_KEY, LANGFUSE_PUBLIC_KEY, LANGFUSE_SECRET_KEY,
#      COHERE_API_KEY, EMAIL_HOST_PASSWORD
#   3. Enable pgvector on the PostgreSQL database:
#      psql <DATABASE_URL> -c "CREATE EXTENSION IF NOT EXISTS vector;"
#   4. Verify: curl https://<your-backend>/api/health/
#   5. Run smoke test: ./scripts/smoke-test.sh https://<your-backend>
#
# Railway deployment checklist:
#   DJANGO_SECRET_KEY, DJANGO_DEBUG=False, ALLOWED_HOSTS=.up.railway.app,
#   DATABASE_URL, REDIS_URL, CORS_ALLOWED_ORIGINS, CSRF_TRUSTED_ORIGINS,
#   EMAIL_HOST_PASSWORD, DEFAULT_FROM_EMAIL, OPENAI_API_KEY,
#   LANGFUSE_PUBLIC_KEY, LANGFUSE_SECRET_KEY, COHERE_API_KEY
# =============================================================================
