# =============================================================================
# SmartStock AI — Backend environment configuration
# Copy this file to `.env` and fill in real values. The `.env` file is
# git-ignored and must never be committed.
#
# REQUIRED variables: the app will refuse to start if any are missing.
# OPTIONAL variables: defaults are shown in brackets after the description.
# =============================================================================

# =============================================================================
# REQUIRED — The app will raise ImproperlyConfigured at startup if missing
# =============================================================================

# Django core
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string

# Database — Neon PostgreSQL
# Get the connection string from https://console.neon.tech → your project →
# "Connection Details" → "Pooled connection".
# Neon requires TLS, so sslmode=require is mandatory.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxxxx.region.aws.neon.tech/smartstock?sslmode=require

# Redis (broker + cache + Celery)
# Local dev: a Redis running on localhost (e.g. `docker run -p 6379:6379 redis`).
# Railway:  create the Redis plugin and reference its $REDIS_URL variable.
REDIS_URL=redis://localhost:6379/0

# AI / LLM
OPENAI_API_KEY=

# Langfuse — LLM observability and tracing
# Sign up at https://cloud.langfuse.com and create a project.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Cohere — embeddings for RAG
COHERE_API_KEY=

# =============================================================================
# OPTIONAL — Defaults shown in brackets; override as needed
# =============================================================================

# Langfuse host URL [default: https://cloud.langfuse.com]
# LANGFUSE_HOST=https://cloud.langfuse.com

# Django debug mode [default: False]
# DJANGO_DEBUG=False

# Allowed hosts (comma-separated) [default: localhost,127.0.0.1]
ALLOWED_HOSTS=localhost,127.0.0.1,.up.railway.app

# CORS / CSRF (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://smart-stock-dev.vercel.app
CSRF_TRUSTED_ORIGINS=https://smart-stock-dev.vercel.app

# Legacy database fallback (only used if DATABASE_URL is unset)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=smartstock
DB_USER=smartstock
DB_PASSWORD=smartstock
DB_HOST=localhost
DB_PORT=5432

# Celery broker/result (defaults to REDIS_URL if unset)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email (SendGrid)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@smartstock.ai

# =============================================================================
# Railway env-var checklist (set these in the Railway dashboard):
#   DJANGO_SECRET_KEY, DJANGO_DEBUG=False, ALLOWED_HOSTS=.up.railway.app,
#   DATABASE_URL  (paste the Neon pooled connection string)
#   REDIS_URL     (auto-injected by the Railway Redis plugin)
#   CORS_ALLOWED_ORIGINS, CSRF_TRUSTED_ORIGINS, EMAIL_HOST_PASSWORD,
#   DEFAULT_FROM_EMAIL, OPENAI_API_KEY, LANGFUSE_PUBLIC_KEY,
#   LANGFUSE_SECRET_KEY, COHERE_API_KEY
# =============================================================================
