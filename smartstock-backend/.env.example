# =============================================================================
# SmartStock AI — Backend environment configuration
# Copy this file to `.env` and fill in real values. The `.env` file is
# git-ignored and must never be committed.
# =============================================================================

# Django core
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DJANGO_DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.up.railway.app

# Database — Neon PostgreSQL
# Get the connection string from https://console.neon.tech → your project →
# "Connection Details" → "Pooled connection".
# Neon requires TLS, so sslmode=require is mandatory.
# This value is read by dj-database-url; the legacy DB_* variables below are
# only used as a fallback when DATABASE_URL is empty.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxxxx.region.aws.neon.tech/smartstock?sslmode=require

# Legacy fallback (only used if DATABASE_URL is unset)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=smartstock
DB_USER=smartstock
DB_PASSWORD=smartstock
DB_HOST=localhost
DB_PORT=5432

# CORS / CSRF
# Comma-separated. Include the production frontend URL when deploying.
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://smart-stock-dev.vercel.app
CSRF_TRUSTED_ORIGINS=https://smart-stock-dev.vercel.app

# Redis (broker + cache + Celery)
# Local dev: a Redis running on localhost (e.g. `docker run -p 6379:6379 redis`).
# Railway:  create the Redis plugin and reference its $REDIS_URL variable.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email (SendGrid)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@smartstock.ai

# AI / LLM
OPENAI_API_KEY=

# =============================================================================
# Railway env-var checklist (set these in the Railway dashboard):
#   DJANGO_SECRET_KEY, DJANGO_DEBUG=False, ALLOWED_HOSTS=.up.railway.app,
#   DATABASE_URL  (paste the Neon pooled connection string)
#   REDIS_URL     (auto-injected by the Railway Redis plugin)
#   CORS_ALLOWED_ORIGINS, CSRF_TRUSTED_ORIGINS, EMAIL_HOST_PASSWORD,
#   DEFAULT_FROM_EMAIL, OPENAI_API_KEY
# =============================================================================
