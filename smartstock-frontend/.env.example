# SmartStock AI — Frontend environment configuration
# Copy this file to `.env.local` and adjust as needed.

# Backend API URL — proxied through Vite in dev, absolute in production
VITE_API_URL=/api

# When true, authentication is bypassed for development
VITE_AUTH_BYPASS=false

# Backend URL for production builds (set to your deployed backend URL)
# VITE_API_BASE_URL=/api
