# SmartStock AI — Frontend environment configuration
# Copy this file to `.env.local` and adjust as needed.
# All VITE_ variables are embedded at build time by Vite.
# In Docker, docker-entrypoint.sh injects them into window.__ENV__ at runtime.

# ─── API Configuration ────────────────────────────────────────────

# Base path for backend API requests.
# In dev: proxied through Vite to localhost:8000
# In Docker/Nginx: proxied to backend:8000
# In production (non-Docker): set to your full backend URL
VITE_API_URL=/api

# Optional: absolute backend URL for production builds (overrides proxy)
# Example: VITE_API_BASE_URL=https://smartstock-api.railway.app
# VITE_API_BASE_URL=

# ─── Feature Flags ────────────────────────────────────────────────

# When "true", authentication checks are bypassed (dev only)
# Default: false
VITE_AUTH_BYPASS=false
